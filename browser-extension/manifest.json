{
  "manifest_version": 3,
  "name": "Trail Overlay for Strava",
  "version": "1.0.0",
  "description": "Overlays mountain bike trails on Strava maps",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "permissions"
  ],
  "host_permissions": [
    "https://www.strava.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.strava.com/maps/create/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.strava.com/maps/create/*"
      ],
      "js": [
        "content-init.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.strava.com/maps/create/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html",
    "default_title": "Trail Overlay Settings"
  }
}