{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Migrate Local DB",
      "type": "shell",
      "command": "node scripts/migrate-local.mjs",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-c"]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Setup Local DB",
      "type": "shell",
      "command": "docker-compose up -d && sleep 3 && node scripts/migrate-local.mjs",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-c"]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Sync Prod → Local",
      "type": "shell",
      "command": "source .env.local && echo \"Fetching $PROD_APP_URL/api/dev/dump...\" && curl -f --show-error -H \"x-dev-dump-secret: $DEV_DUMP_SECRET\" \"$PROD_APP_URL/api/dev/dump\" -o /tmp/seed-data.json && node scripts/seed-local.mjs /tmp/seed-data.json",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-c"]
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
